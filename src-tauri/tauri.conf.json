{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenBao Certificate Client",
  "version": "0.1.0",
  "identifier": "org.openbao.certificate-client",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenBao Certificates",
        "width": 680,
        "height": 720,
        "minWidth": 440,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Enroll certificates from OpenBao",
    "longDescription": "Per-user Windows root trust and certificate enrollment through OpenBao and OIDC.",
    "resources": ["resources/deployment.json"],
    "windows": {
      "webviewInstallMode": { "type": "skip" },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
