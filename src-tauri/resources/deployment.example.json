{
  "schema_version": 1,
  "configured": true,
  "deployment_name": "Example Homelab",
  "openbao": {
    "address": "https://bao.home.example:8200",
    "namespace": null,
    "auth_mount": "oidc",
    "oidc_role": "desktop-certificates",
    "minimum_version": "2.5.5"
  },
  "identity": {
    "display_claim": "preferred_username",
    "subject_claim": "email"
  },
  "roots": [
    {
      "id": "homelab-root-2026",
      "pem": "-----BEGIN CERTIFICATE-----\nREPLACE_WITH_BASE64_DER\n-----END CERTIFICATE-----\n",
      "sha256": "REPLACE_WITH_64_CHARACTER_LOWERCASE_SHA256",
      "refresh_path": "pki-root/ca/pem"
    }
  ],
  "profiles": [
    {
      "id": "user-mtls",
      "label": "User mTLS",
      "description": "Client authentication for homelab services",
      "purpose": "mtls",
      "pki_mount": "pki-users",
      "pki_role": "user-mtls",
      "subject_claim": "email",
      "san_claim": "email",
      "destination_store": "My",
      "key_algorithm": "rsa-3072",
      "expected_eku_oids": ["1.3.6.1.5.5.7.3.2"]
    },
    {
      "id": "office-document-signing",
      "label": "Office document signing",
      "description": "Personal signing certificate for Microsoft Office",
      "purpose": "document-signing",
      "pki_mount": "pki-users",
      "pki_role": "office-document-signing",
      "subject_claim": "email",
      "san_claim": null,
      "destination_store": "My",
      "key_algorithm": "rsa-3072",
      "expected_eku_oids": ["1.3.6.1.4.1.311.10.3.12"]
    },
    {
      "id": "internal-code-signing",
      "label": "Internal code signing",
      "description": "Code signing trusted only by enrolled homelab machines",
      "purpose": "code-signing",
      "pki_mount": "pki-users",
      "pki_role": "internal-code-signing",
      "subject_claim": "email",
      "san_claim": null,
      "destination_store": "My",
      "key_algorithm": "rsa-3072",
      "expected_eku_oids": ["1.3.6.1.5.5.7.3.3"]
    }
  ]
}
